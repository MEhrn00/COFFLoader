{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "mingw",
      "inherits": "base",
      "displayName": "mingw Config",
      "toolchainFile": "${sourceDir}/cmake/toolchain-mingw.cmake"
    },
    {
      "name": "mingw64",
      "inherits": "mingw",
      "displayName": "mingw64 Config",
      "cacheVariables": {
        "CMAKE_SYSTEM_PROCESSOR": "x86_64"
      }
    },
    {
      "name": "mingw32",
      "inherits": "mingw",
      "displayName": "mingw32 Config",
      "cacheVariables": {
        "CMAKE_SYSTEM_PROCESSOR": "i386"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw",
      "configurePreset": "mingw"
    },
    {
      "name": "mingw64",
      "configurePreset": "mingw64"
    },
    {
      "name": "mingw32",
      "configurePreset": "mingw32"
    }
  ]
}
